{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/spec",
    "typeRoots": ["../../node_modules/@types", "../../node_modules"],
    "types": ["vitest/globals"],
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["**/*.spec.ts", "**/*.test.ts"],
  "angularCompilerOptions": {
    "strictTemplates": false
  }
}
